# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# JWT
JWT_SECRET=change_me_to_a_long_random_secret

# Server Configuration
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Auth rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT=12
AUTH_REGISTER_RATE_LIMIT=6

# Global API rate limiting
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300

# Optional seed credentials (avoid weak defaults in production)
DEFAULT_MAIN_ACCOUNT_EMAIL=main@example.com
DEFAULT_MAIN_ACCOUNT_PASSWORD=change_me
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me
